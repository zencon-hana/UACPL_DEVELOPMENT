managed implementation in class zcl_bp_c_api_usr unique;
strict ( 2 );

define behavior for ZC_API_USR //alias <alias_name>
persistent table zapi_usr
lock master
authorization master ( instance )
//etag master <field_name>
{
  create;
  update;
  delete;
  //  field ( readonly ) ApiUser, Sysid;
  mapping for zapi_usr
    {
      ApiUser  = api_user;
      Sysid    = sysid;
      Password = password;
    }
}