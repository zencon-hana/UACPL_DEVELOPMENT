  Supplier;

  @UI: { lineItem: [{ position: 52, importance: #HIGH }],
        identification: [{ position: 52, label: 'Supplier' }] }
  SupplierName;

  @UI: { lineItem: [{ position: 60, importance: #HIGH }],
