  //  @UI: { lineItem: [{ position: 70, importance: #HIGH }],
  //         identification: [{ position: 70, label: 'Net price amount' }] }
  //  NetPriceAmount;
  @UI: { lineItem: [{ position: 70, importance: #HIGH }],
