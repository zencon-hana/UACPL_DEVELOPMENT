@Metadata.layer: #CUSTOMER
@UI.headerInfo:{ typeName: 'MIRO utility',
                 typeNamePlural: 'MIRO utilities',
                 title: { type: #STANDARD, value: 'PurchaseOrder' } }
annotate entity ZC_MIRO_P with
{
  @UI.facet: [{ id: 'idPODetail',
                  type: #IDENTIFICATION_REFERENCE,
                  position: 10,
                  label: 'PO detail' }]

  @UI: { lineItem: [{ position: 10, importance: #HIGH },
                    { type: #FOR_ACTION, position: 10, dataAction: 'CalcAndShowTotal', label:'Show Total', invocationGrouping: #CHANGE_SET },
                    { type: #FOR_ACTION, position: 20, dataAction: 'ParkInvoice', label:'Park Invoice', invocationGrouping: #CHANGE_SET }
                   ],
       identification: [{ position: 10, label: 'Purchase order' }],
       selectionField: [{ position: 10 }] }
  PurchaseOrder;

  @UI: { lineItem: [{ position: 20, importance: #HIGH }],
         identification: [{ position: 20, label: 'Purchase order Item' }] }
  PurchaseOrderItem;

  @UI: { lineItem: [{ position: 21, importance: #HIGH }, { type: #FOR_INTENT_BASED_NAVIGATION, semanticObjectAction: 'park' }],
         identification: [{ position: 21, label: 'Bill Passing number' }] }
  SupplierInvoice;

  @UI: { lineItem: [{ position: 22, importance: #HIGH }],
         identification: [{ position: 22, label: 'Bill Passing Item' }] }
  SupplierInvoiceItem;

  @UI: { lineItem: [{ position: 23, importance: #HIGH }],
