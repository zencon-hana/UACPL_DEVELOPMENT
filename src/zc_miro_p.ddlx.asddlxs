  ServiceEntrySheetItem;

  @UI: { lineItem: [{ position: 30, importance: #HIGH }],
         identification: [{ position: 30, label: 'Material' }] ,
         selectionField: [{ position: 20 }] }
  Material;

  @UI: { lineItem: [{ position: 31, importance: #HIGH }],
         identification: [{ position: 31, label: 'Material Description' }] }
  MaterialDescription;

  @UI: { lineItem: [{ position: 32, importance: #HIGH }],
         identification: [{ position: 32, label: 'HSN Code' }] }
  ConsumptionTaxCtrlCode;

  @UI: { lineItem: [{ position: 40, importance: #HIGH }],
         identification: [{ position: 40, label: 'Company code' }],
         selectionField: [{ position: 30 }] }
  CompanyCode;

  @UI: { lineItem: [{ position: 50, importance: #HIGH }],
